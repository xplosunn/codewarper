{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "customConditions": ["development"],
    "strict": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/**/*.ts", "libs/**/*.ts"],
  "exclude": ["**/*.unit.test.ts", "test/**/*.ts"]
}
